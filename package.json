{
  "name": "webcontext-ai",
  "version": "1.1.0",
  "description": "Turn any web content into clean AI-ready context — with crawling, chunking, semantic search, and MCP tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "webcontext": "./dist/cli/index.js",
    "webcontext-mcp": "./dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./sdk/client": {
      "types": "./dist/sdk/client.d.ts",
      "require": "./dist/sdk/client.js"
    },
    "./sdk/mcp": {
      "types": "./dist/sdk/mcp.d.ts",
      "require": "./dist/sdk/mcp.js"
    },
    "./search": {
      "types": "./dist/search/vector.d.ts",
      "require": "./dist/search/vector.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "require": "./dist/utils/index.js"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "require": "./dist/export/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/index.ts",
    "cli": "ts-node src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "serve": "node dist/cli/index.js serve",
    "test": "jest",
    "lint": "eslint src/"
  },
  "keywords": [
    "web-scraping",
    "ai-context",
    "llm",
    "rag",
    "markdown",
    "crawling",
    "web-crawler",
    "documentation",
    "firecrawl",
    "mcp",
    "vector-search",
    "sitemap",
    "tfidf",
    "semantic-search",
    "mcp-server",
    "langchain",
    "pdf-extraction",
    "github",
    "deduplication"
  ],
  "author": "sumeethmoolya",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sumeeth-24/webScrapper-ai.git"
  },
  "homepage": "https://github.com/Sumeeth-24/webScrapper-ai#readme",
  "license": "MIT",
  "dependencies": {
    "chalk": "4.1.2",
    "cheerio": "1.0.0-rc.12",
    "commander": "12.1.0",
    "cors": "2.8.5",
    "express": "4.19.2",
    "lru-cache": "10.2.2",
    "ora": "5.4.1",
    "p-queue": "6.6.2",
    "robots-parser": "3.0.1",
    "tiktoken": "1.0.15",
    "turndown": "7.2.0",
    "zod": "3.23.8"
  },
  "optionalDependencies": {
    "pdf-parse": "1.1.1",
    "playwright": "1.44.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.12.12",
    "@types/turndown": "5.0.4",
    "eslint": "9.3.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.4",
    "ts-node": "10.9.2",
    "typescript": "5.4.5"
  }
}
